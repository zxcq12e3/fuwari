const setup = () => {
	Fancybox.bind(".custom-md img, #post-cover img", {
		wheel: 'zoom',
		clickContent: 'close',
		dblclickContent: 'zoom',
		click: 'close',
		dblclick: 'zoom',
		Panels: {
			display: ['counter', 'zoom']
		},
		Images: {
			panning: true,
			zoom: true,
			protect: false
		}
	})

	window.swup.hooks.on("page:view", () => {
		Fancybox.bind(".custom-md img, #post-cover img", {
			wheel: 'zoom',
			clickContent: 'close',
			dblclickContent: 'zoom',
			click: 'close',
			dblclick: 'zoom',
			Panels: {
				display: ['counter', 'zoom']
			},
			Images: {
				panning: true,
				zoom: true,
				protect: false
			}
		})
	})

	window.swup.hooks.on(
		"content:replace",
		() => {
			Fancybox.unbind(".custom-md img, #post-cover img")
		},
		{ before: true },
	)
}

if (window.swup) {
	setup()
} else {
	document.addEventListener("swup:enable", setup)
}
